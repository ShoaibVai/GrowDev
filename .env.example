APP_NAME=GrowDev
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.herokuapp.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (Neon) ---
DATABASE_URL=
DB_CONNECTION=pgsql

# --- Queue & Session ---
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=file

# --- Cloudflare R2 ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=https://29f49804ae24d1e44c23a4385a116446.r2.cloudflarestorage.com
R2_URL=https://pub-xxxx.r2.dev

# --- Pusher ---
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1
BROADCAST_DRIVER=pusher

# --- Vite (frontend) ---
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@growdev.app
MAIL_FROM_NAME="${APP_NAME}"

# --- OpenRouter AI ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://your-app.herokuapp.com